@model IEnumerable<Rastreador_de_Gastos_Personales.Models.Gasto>

<!DOCTYPE html>
<html lang="es">
<head>
    <title>Mis Gastos</title>
    <style>
        .alerta-roja { background-color: #f8d7da; color: #721c24; font-weight: bold; }
    </style>
</head>
<body>

    <h1>Bienvenido, @ViewBag.NombreUsuario</h1>
    <h3>Total Gastado: $@ViewBag.TotalGastado</h3>

    <table border="1" style="width:100%; border-collapse: collapse;">
        <thead>
            <tr>
                <th>Descripción</th>
                <th>Monto</th>
                <th>Categoría</th>
            </tr>
        </thead>
        <tbody>
           
            @foreach (var gasto in Model)
            {
                <tr class="@(gasto.Monto > 50 ? "alerta-roja" : "")">
                    <td>@gasto.Descripcion</td>
                    <td>$@gasto.Monto</td>
                    <td>@gasto.Categoria</td>
                </tr>
            }
        </tbody>
    </table>

</body>
</html>